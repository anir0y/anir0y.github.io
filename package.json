{
  "name": "anir0y-secops",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "description": "anir0y // Security Operations Command \u2014 cinematic WebGL portfolio for Animesh Roy",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/gen-health.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 8009",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:cf": "npx -y wrangler pages deploy dist --project-name anir0y",
    "deploy:netlify": "npx -y netlify-cli deploy --prod --dir dist"
  },
  "dependencies": {
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-type-animation": "^3.2.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
