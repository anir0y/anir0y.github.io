# ============================================================================
#  anir0y // SECOPS — deploy secrets        ⚠ LOCAL ONLY — gitignored, never commit
# ----------------------------------------------------------------------------
#  Fill in the values, then deploy to all mirrors with:
#       ./scripts/deploy-all.sh
#  (the script sources this file). Or load manually:
#       set -a; source ./secret.conf; set +a
#       npm run deploy:cf        # Cloudflare Pages
#       npm run deploy:netlify   # Netlify
#
#  For CI/CD do NOT use this file — put the same keys in GitHub repo Secrets
#  (Settings → Secrets and variables → Actions). See MULTIHOST.md.
# ============================================================================

# ── Cloudflare Pages ────────────────────────────────────────────────────────
#  Token:  Cloudflare → My Profile → API Tokens → template "Edit Cloudflare Pages"
#  Acct ID: any zone's Overview page (right sidebar)
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_PAGES_PROJECT="anir0y"

# ── Netlify ─────────────────────────────────────────────────────────────────
#  Token:   Netlify → User settings → Applications → Personal access tokens
#  Site ID: Site configuration → General → Site information → Site ID (API ID)
NETLIFY_AUTH_TOKEN=""
NETLIFY_SITE_ID=""

# ── Fastly (optional — only if Fastly sits in the path) ─────────────────────
FASTLY_API_TOKEN=""
FASTLY_SERVICE_ID=""

# ── Health-check URLs (deploy-all.sh confirms each mirror after deploy) ─────
CF_URL=""        # e.g. https://anir0y.pages.dev
NETLIFY_URL=""   # e.g. https://anir0y.netlify.app
