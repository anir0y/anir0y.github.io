/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://api.ipapi.is https://ipwho.is https://api.ipify.org; base-uri 'self'; frame-ancestors 'none'; form-action 'self'

# Fingerprinted assets are immutable — cache hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Entry + health must always re-validate so new deploys go live instantly.
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/health.json
  Cache-Control: public, max-age=0, must-revalidate
