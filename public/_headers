/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://www.clarity.ms https://rum.cronitor.io https://cdn.consentmanager.net https://*.consentmanager.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://www.google-analytics.com https://*.google-analytics.com https://*.clarity.ms https://*.consentmanager.net https://cataas.com; connect-src 'self' https://api.ipapi.is https://ipwho.is https://api.ipify.org https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://stats.g.doubleclick.net https://*.clarity.ms https://rum.cronitor.io https://*.cronitor.io https://*.consentmanager.net; frame-src https://*.consentmanager.net; base-uri 'self'; frame-ancestors 'none'; form-action 'self'

# Fingerprinted assets are immutable — cache hard.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Entry + health must always re-validate so new deploys go live instantly.
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/health.json
  Cache-Control: public, max-age=0, must-revalidate
